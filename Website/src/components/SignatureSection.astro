---
interface Props {
  t: Record<string, any>;
}

const { t } = Astro.props;
const s = t.signature;

const cards = [
  {
    key:   'cupping',
    image: '/images/treatment-cupping.jpg',
    alt:   'Air cupping therapy treatment at Calma',
    href:  '#services',
    tabTarget: 'massage',
  },
  {
    key:   'recovery',
    image: '/images/treatment-head-massage.jpg',
    alt:   'Sport recovery massage at Calma',
    href:  '#services',
    tabTarget: 'massage',
  },
  {
    key:   'facial',
    image: '/images/treatment-facial-thalgo.jpg',
    alt:   'Thalgo marine facial treatment at Calma',
    href:  '#services',
    tabTarget: 'salon',
  },
];
---

<section id="signature" class="bg-warm-stone section-wrap">
  <div class="content-wrap">

    <div class="text-center mb-14 reveal">
      <div class="inline-flex items-center gap-3 mb-4">
        <span class="block h-px w-8 bg-gold-accent/50" aria-hidden="true"></span>
        <p class="eyebrow">{s.eyebrow}</p>
        <span class="block h-px w-8 bg-gold-accent/50" aria-hidden="true"></span>
      </div>
      <h2 class="section-headline font-display text-text-primary font-medium leading-display">{s.headline}</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {cards.map(({ key, image, alt, href, tabTarget }, i) => {
        const card = s[key as keyof typeof s] as { name: string; benefit: string };
        return (
          <a
            href={`${href}?tab=${tabTarget}`}
            data-tab-target={tabTarget}
            class="signature-card group block rounded-card overflow-hidden bg-warm-cream shadow-card hover:shadow-card-hover hover:-translate-y-1 transition-all duration-[350ms] ease-[cubic-bezier(0.22,1,0.36,1)] reveal"
            style={`transition-delay: ${i * 80}ms`}
          >
            <!-- Image -->
            <div class="aspect-[4/3] overflow-hidden">
              <img
                src={image}
                alt={alt}
                width="600"
                height="450"
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-[600ms] ease-[cubic-bezier(0.22,1,0.36,1)]"
              />
            </div>

            <!-- Content -->
            <div class="p-6">
              <h3 class="font-display text-h3 text-text-primary font-medium leading-display mb-3">
                {card.name}
              </h3>
              <p class="font-body text-small text-text-muted leading-body mb-4">
                {card.benefit}
              </p>
              <span class="inline-flex items-center gap-1.5 text-small font-semibold font-body text-calma-mid group-hover:gap-3 transition-all duration-300">
                {s.learn_more}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="icon-directional" aria-hidden="true">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </span>
            </div>
          </a>
        );
      })}
    </div>

  </div>
</section>

<script>
  /* When clicking a signature card, scroll to services and activate the correct tab */
  document.querySelectorAll<HTMLAnchorElement>('.signature-card').forEach(card => {
    card.addEventListener('click', e => {
      e.preventDefault();
      const tabKey = card.dataset.tabTarget;
      const section = document.getElementById('services');
      if (!section) return;

      section.scrollIntoView({ behavior: 'smooth', block: 'start' });

      if (tabKey) {
        setTimeout(() => {
          const btn = document.querySelector<HTMLButtonElement>(`[data-tab="${tabKey}"]`);
          btn?.click();
        }, 400);
      }
    });
  });
</script>
