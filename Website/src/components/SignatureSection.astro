---
interface Props {
  t: Record<string, any>;
}
const { t } = Astro.props;
const s = t.signature;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const FRESHA_URL = "https://www.fresha.com/a/calma-massage-spa-seef-road-3627-nyt1nacu";

const cards = [
  {
    n: "01",
    en: s.card1_en,
    ar: s.card1_ar,
    blurb: s.card1_blurb,
    duration: s.card1_duration,
    price: s.card1_price,
    img: "treatment-facial-thalgo.jpg",
  },
  {
    n: "02",
    en: s.card2_en,
    ar: s.card2_ar,
    blurb: s.card2_blurb,
    duration: s.card2_duration,
    price: s.card2_price,
    img: "room-treatment-find-peace.jpg",
  },
  {
    n: "03",
    en: s.card3_en,
    ar: s.card3_ar,
    blurb: s.card3_blurb,
    duration: s.card3_duration,
    price: s.card3_price,
    img: "treatment-deep-cleanse-steam.jpg",
  },
];
---

<section id="signature" class="section signature">
  <div class="container">

    <div class="section-head reveal">
      <h2 class="h2">
        {s.head_line1} <span class="italic">{s.head_italic}</span>
      </h2>
      <div class="meta">
        <span class="eyebrow">{s.eyebrow}</span>
        <p class="lead">{s.lead}</p>
      </div>
    </div>

    <div class="sig-grid">
      {cards.map((card, i) => (
        <a
          class="sig-card reveal"
          href={FRESHA_URL}
          target="_blank"
          rel="noopener noreferrer"
          style={`transition-delay: ${i * 60}ms`}
        >
          <div class="sig-photo">
            <span class="sig-index">{card.n} / 03</span>
            <img
              src={`${base}/images/${card.img}`}
              alt=""
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="sig-body">
            <p class="ar">{card.ar}</p>
            <h3 class="name">{card.en}</h3>
            <p class="blurb">{card.blurb}</p>
            <div class="sig-meta">
              <span>{card.duration}</span>
              <span class="price">{card.price}</span>
            </div>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>
