---
import LanguageToggle from './LanguageToggle.astro';

interface Props {
  t: Record<string, any>;
  lang: 'en' | 'ar';
  currentPath: string;
}

const { t, lang, currentPath } = Astro.props;
const nav = t.nav;
const FRESHA_URL = "https://www.fresha.com/a/calma-massage-spa-seef-road-3627-nyt1nacu";
---

<header id="site-header" class="header">
  <div class="container header-inner">

    <!-- Brand -->
    <a href={lang === 'ar' ? '/ar' : '/'} class="brand" aria-label={t.aria.logo}>
      <span>CALMA</span>
      <span class="dot" aria-hidden="true"></span>
    </a>

    <!-- Desktop nav -->
    <nav class="header-nav" aria-label="Primary navigation">
      <a href="#space">{nav.experience}</a>
      <a href="#signature">{nav.signature}</a>
      <a href="#services">{nav.services}</a>
      <a href="#visit">{nav.visit}</a>
    </nav>

    <!-- Right actions -->
    <div class="header-cta">
      <LanguageToggle
        currentLang={lang}
        currentPath={currentPath}
        label={nav.lang_toggle}
        ariaLabel={t.aria.lang_toggle}
      />
      <a
        href={FRESHA_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-filled hidden-mobile"
        aria-label={t.aria.book_fresha}
      >{nav.book_now}</a>
      <!-- Mobile hamburger -->
      <button
        id="hamburger"
        type="button"
        aria-label={nav.open_menu}
        aria-expanded="false"
        aria-controls="mobile-drawer"
        class="hamburger-btn"
      >
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile drawer -->
<div
  id="mobile-drawer"
  role="dialog"
  aria-modal="true"
  aria-label={nav.open_menu}
  class="mobile-drawer"
>
  <nav class="drawer-nav" aria-label="Mobile navigation">
    <a href="#space" data-close-drawer>{nav.experience}</a>
    <a href="#signature" data-close-drawer>{nav.signature}</a>
    <a href="#services" data-close-drawer>{nav.services}</a>
    <a href="#visit" data-close-drawer>{nav.visit}</a>
  </nav>
  <div class="drawer-ctas">
    <a
      href={FRESHA_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="btn btn-filled"
      data-close-drawer
    >{nav.book_now}</a>
  </div>
</div>

<style>
  .hidden-mobile {
    display: none;
  }
  @media (min-width: 640px) {
    .hidden-mobile { display: inline-flex; }
  }

  .hamburger-btn {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    padding: 8px;
    background: transparent;
    border: 0;
    cursor: pointer;
    color: inherit;
  }
  @media (min-width: 900px) {
    .hamburger-btn { display: none; }
  }

  .hamburger-line {
    display: block;
    height: 1px;
    width: 24px;
    background: currentColor;
    transition: all 300ms cubic-bezier(0.22, 1, 0.36, 1);
    transform-origin: center;
  }

  /* Mobile drawer */
  .mobile-drawer {
    position: fixed;
    inset: 0;
    z-index: 40;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    background: var(--calma-deep);
    color: var(--warm-cream);
    transform: translateX(100%);
    transition: transform 500ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  [dir="rtl"] .mobile-drawer {
    transform: translateX(-100%);
  }
  .mobile-drawer.open {
    transform: translateX(0);
  }

  .drawer-nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
    text-align: center;
  }
  .drawer-nav a {
    font-family: var(--ff-display);
    font-size: clamp(28px, 6vw, 42px);
    font-weight: 400;
    color: var(--warm-cream);
    opacity: 0.85;
    transition: opacity 200ms;
  }
  .drawer-nav a:hover { opacity: 1; }

  .drawer-ctas {
    margin-top: 48px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
</style>

<script>
  const header    = document.getElementById('site-header')!;
  const hamburger = document.getElementById('hamburger')!;
  const drawer    = document.getElementById('mobile-drawer')!;
  const lines     = hamburger.querySelectorAll<HTMLElement>('.hamburger-line');

  /* Sticky backdrop once past hero */
  const onScroll = () => {
    const past = window.scrollY > 60;
    header.classList.toggle('scrolled', past);
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  /* Drawer open/close */
  const openDrawer = () => {
    drawer.classList.add('open');
    hamburger.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
    lines[0].style.transform = 'translateY(6px) rotate(45deg)';
    lines[1].style.opacity = '0';
    lines[2].style.transform = 'translateY(-6px) rotate(-45deg)';
  };

  const closeDrawer = () => {
    drawer.classList.remove('open');
    hamburger.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    lines[0].style.transform = '';
    lines[1].style.opacity = '';
    lines[2].style.transform = '';
  };

  hamburger.addEventListener('click', () => {
    drawer.classList.contains('open') ? closeDrawer() : openDrawer();
  });

  drawer.querySelectorAll('[data-close-drawer]').forEach(el =>
    el.addEventListener('click', closeDrawer)
  );

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') closeDrawer();
  });
</script>
