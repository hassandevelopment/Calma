---
interface Props {
  t: Record<string, any>;
}
const { t } = Astro.props;
const g = t.gallery;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const FRESHA_URL = "https://www.fresha.com/a/calma-massage-spa-seef-road-3627-nyt1nacu";

const tiles = [
  { n: "01", label: g.tile2_label, meta: g.tile2_meta, img: "venue-treatment-room.jpg",  feature: false },
  { n: "02", label: g.tile3_label, meta: g.tile3_meta, img: "venue-massage-candles.jpg", feature: false },
  { n: "03", label: g.tile1_label, meta: g.tile1_meta, img: "venue-hammam.jpg",          feature: true  },
];
---

<section class="section gallery">
  <div class="container">

    <div class="section-head reveal">
      <h2 class="h2">
        {g.head_line1} <span class="italic">{g.head_italic}</span>
      </h2>
      <div class="meta">
        <span class="eyebrow">{g.eyebrow}</span>
        <p class="lead">{g.lead}</p>
      </div>
    </div>

    <div class="gallery-grid">
      {tiles.map((tile, i) => (
        <a
          class={`gallery-tile reveal ${tile.feature ? 'feature' : ''}`}
          href={FRESHA_URL}
          target="_blank"
          rel="noopener noreferrer"
          style={`transition-delay: ${i * 60}ms`}
        >
          <div class="gallery-photo">
            <img
              src={`${base}/images/${tile.img}`}
              alt={tile.label}
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="gallery-cap">
            <div>
              <div class="num">{tile.n} / 04</div>
              <div class="label">{tile.label}</div>
            </div>
            <div class="meta">{tile.meta}</div>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>
