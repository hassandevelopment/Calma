---
interface Props {
  t: Record<string, any>;
}
const { t } = Astro.props;
const v = t.visit;
const MAPS_URL     = "https://maps.app.goo.gl/pMESauvQZ3H1NGZX6";
const WHATSAPP_URL = "https://wa.me/97366677745";
---

<section id="visit" class="section visit">
  <div class="container">

    <div class="section-head reveal">
      <h2 class="h2">
        {v.head_line1} <span class="italic">{v.head_italic}</span>
      </h2>
      <div class="meta">
        <span class="eyebrow">{v.eyebrow}</span>
        <p class="lead">{v.lead}</p>
      </div>
    </div>

    <div class="visit-grid">

      <!-- Left: spec + ctas + amenities -->
      <div class="reveal">
        <div class="visit-spec">
          <div class="visit-row">
            <div class="k">{v.row1_k}</div>
            <div class="v">{v.row1_v}<small>{v.row1_sub}</small></div>
          </div>
          <div class="visit-row">
            <div class="k">{v.row2_k}</div>
            <div class="v">{v.row2_v}<small>{v.row2_sub}</small></div>
          </div>
          <div class="visit-row">
            <div class="k">{v.row3_k}</div>
            <div class="v">{v.row3_v}<small>{v.row3_sub}</small></div>
          </div>
          <div class="visit-row">
            <div class="k">{v.row4_k}</div>
            <div class="v">{v.row4_v}<small>{v.row4_sub}</small></div>
          </div>
        </div>

        <div class="visit-ctas">
          <a
            class="btn btn-filled"
            href={MAPS_URL}
            target="_blank"
            rel="noopener noreferrer"
            style="background: var(--gold); color: var(--calma-deep)"
          >{v.directions_cta}</a>
          <a
            class="btn btn-outline inverse"
            href={WHATSAPP_URL}
            target="_blank"
            rel="noopener noreferrer"
          >{v.whatsapp_cta}</a>
        </div>

        <div class="amenities" aria-label={v.amenities_aria}>
          {(v.amenities as string[]).map((a: string) => <span>{a}</span>)}
        </div>
      </div>

      <!-- Right: SVG map card -->
      <a href={MAPS_URL} target="_blank" rel="noopener noreferrer" class="map-card reveal" aria-label={t.aria.map}>
        <svg viewBox="0 0 400 500" preserveAspectRatio="none">
          <defs>
            <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
              <path d="M 40 0 L 0 0 0 40" fill="none" stroke="rgba(245,240,232,0.06)" stroke-width="1" />
            </pattern>
          </defs>
          <rect width="400" height="500" fill="url(#grid)" />
          <path d="M 0 200 Q 150 180 220 220 T 400 240" stroke="rgba(245,240,232,0.18)" stroke-width="14" fill="none" stroke-linecap="round" />
          <path d="M 0 200 Q 150 180 220 220 T 400 240" stroke="rgba(245,240,232,0.4)" stroke-width="1" fill="none" />
          <path d="M 180 0 Q 200 200 240 320 T 280 500" stroke="rgba(245,240,232,0.14)" stroke-width="10" fill="none" stroke-linecap="round" />
          <path d="M 0 380 L 400 360" stroke="rgba(245,240,232,0.1)" stroke-width="6" fill="none" stroke-linecap="round" />
          <path d="M 0 430 Q 80 410 180 440 T 400 420 L 400 500 L 0 500 Z" fill="rgba(184,153,104,0.12)" />
          <path d="M 0 430 Q 80 410 180 440 T 400 420" stroke="rgba(184,153,104,0.4)" stroke-width="1" fill="none" />
          <rect x="120" y="160" width="40" height="28" fill="rgba(245,240,232,0.06)" />
          <rect x="260" y="180" width="50" height="34" fill="rgba(245,240,232,0.06)" />
          <rect x="80" y="280" width="56" height="38" fill="rgba(245,240,232,0.06)" />
          <rect x="290" y="300" width="44" height="30" fill="rgba(245,240,232,0.06)" />
        </svg>
        <div class="pin">
          <div class="label">Calma</div>
          <div class="dot"></div>
        </div>
        <div class="map-meta">
          <span>26.2285° N · 50.5584° E</span>
          <span>Al-Seef 436</span>
        </div>
        <div class="map-cta-hint">Open in Maps ↗</div>
      </a>

    </div>
  </div>
</section>
