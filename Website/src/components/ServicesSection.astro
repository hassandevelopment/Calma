---
import services from '../data/services.json';

interface Props {
  t: Record<string, any>;
  lang: 'en' | 'ar';
}

const { t, lang } = Astro.props;
const s = t.services_section;
const FRESHA_URL = "https://www.fresha.com/a/calma-massage-spa-seef-road-3627-nyt1nacu";

const tabs = [
  { id: 'massage', label: s.tab_massage, count: services.massage.length },
  { id: 'spa',     label: s.tab_spa,     count: services.spa.length },
  { id: 'salon',   label: s.tab_salon,   count: services.salon.length },
];

function formatDurations(durs: number[]) {
  return durs.length === 1 ? `${durs[0]} min` : `${durs.join(' / ')} min`;
}

function formatPrice(row: any) {
  if (row.prices.length === 1) {
    return row.priceFrom ? `from BD ${row.prices[0]}` : `BD ${row.prices[0]}`;
  }
  return `BD ${row.prices.join(' / ')}`;
}
---

<section id="services" class="section services">
  <div class="container">

    <div class="section-head reveal">
      <h2 class="h2">
        {s.head_line1} <span class="italic">{s.head_italic}</span>
      </h2>
      <div class="meta">
        <span class="eyebrow">{s.eyebrow}</span>
        <p class="lead">{s.lead}</p>
      </div>
    </div>

    <!-- Tab bar -->
    <div class="tabs" role="tablist" id="services-tabs">
      {tabs.map(tab => (
        <button
          role="tab"
          aria-selected={tab.id === 'massage' ? 'true' : 'false'}
          class={`tab ${tab.id === 'massage' ? 'active' : ''}`}
          data-tab={tab.id}
        >
          {tab.label}<span class="count">{tab.count}</span>
        </button>
      ))}
      <span class="tab-underline" id="tab-underline" aria-hidden="true"></span>
      <span class="tab-meta">{s.price_note}</span>
    </div>

    <!-- Menu panels -->
    {['massage', 'spa', 'salon'].map(category => (
      <div
        class="menu"
        role="tabpanel"
        id={`panel-${category}`}
        data-panel={category}
        style={category !== 'massage' ? 'display:none' : ''}
      >
        {(services as any)[category].map((row: any, i: number) => (
          <a
            class="menu-row reveal in"
            href={FRESHA_URL}
            target="_blank"
            rel="noopener noreferrer"
            style={`animation: fadeIn 380ms cubic-bezier(.22,1,.36,1) both; animation-delay: ${i * 30}ms`}
          >
            <div class="left">
              <span class="en">{row.en}</span>
              <span class="ar">{row.ar}</span>
              {row.note && <span class="row-note">{row.note}</span>}
            </div>
            <div class="right">
              <span class="durs">{formatDurations(row.durations)}</span>
              <span class="prices">
                {row.priceFrom && <span class="from">from</span>}
                BD {row.prices.length === 1 ? row.prices[0] : row.prices.join(' / ')}
              </span>
            </div>
          </a>
        ))}
      </div>
    ))}

    <div class="menu-bottom">
      <p class="note">{s.bottom_note}</p>
      <a class="btn btn-filled" href={FRESHA_URL} target="_blank" rel="noopener noreferrer">
        {s.book_cta}
      </a>
    </div>

  </div>
</section>

<script>
  const tabBtns = document.querySelectorAll<HTMLButtonElement>('[data-tab]');
  const panels  = document.querySelectorAll<HTMLElement>('[data-panel]');
  const underline = document.getElementById('tab-underline')!;
  const tabsList  = document.getElementById('services-tabs')!;

  function moveUnderline(btn: HTMLButtonElement) {
    const parentRect = tabsList.getBoundingClientRect();
    const btnRect    = btn.getBoundingClientRect();
    underline.style.transform = `translateX(${btnRect.left - parentRect.left}px)`;
    underline.style.width     = `${btnRect.width}px`;
  }

  function activateTab(id: string) {
    tabBtns.forEach(b => {
      const active = b.dataset.tab === id;
      b.classList.toggle('active', active);
      b.setAttribute('aria-selected', String(active));
    });
    panels.forEach(p => {
      p.style.display = p.dataset.panel === id ? '' : 'none';
    });
    const activeBtn = document.querySelector<HTMLButtonElement>(`[data-tab="${id}"]`)!;
    moveUnderline(activeBtn);

    // Re-trigger reveal on newly shown rows
    const observer = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('in');
          observer.unobserve(e.target);
        }
      });
    }, { threshold: 0.05 });
    document.querySelectorAll(`[data-panel="${id}"] .reveal:not(.in)`).forEach(el => observer.observe(el));
  }

  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => activateTab(btn.dataset.tab!));
  });

  // Init underline position
  window.addEventListener('load', () => {
    const active = document.querySelector<HTMLButtonElement>('.tab.active');
    if (active) moveUnderline(active);
  });
  window.addEventListener('resize', () => {
    const active = document.querySelector<HTMLButtonElement>('.tab.active');
    if (active) moveUnderline(active);
  });
</script>
