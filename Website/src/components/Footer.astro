---
interface Props {
  t: Record<string, any>;
  lang: 'en' | 'ar';
}
const { t, lang } = Astro.props;
const f = t.footer;
const FRESHA_URL   = "https://www.fresha.com/a/calma-massage-spa-seef-road-3627-nyt1nacu";
const WHATSAPP_URL = "https://wa.me/97366677745";
const INSTAGRAM    = "https://instagram.com/calma_bh";
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">

      <!-- Brand -->
      <div>
        <div class="brand-block">CALMA</div>
        <p>{f.tagline}</p>
      </div>

      <!-- Visit links -->
      <div class="links">
        <h4>{f.col_visit}</h4>
        <a href="#space">{f.link_space}</a>
        <a href="#signature">{f.link_signature}</a>
        <a href="#services">{f.link_services}</a>
        <a href="#visit">{f.link_visit}</a>
      </div>

      <!-- Connect links -->
      <div class="links">
        <h4>{f.col_connect}</h4>
        <a href={INSTAGRAM} target="_blank" rel="noopener noreferrer">{f.link_instagram}</a>
        <a href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer">{f.link_whatsapp}</a>
        <a href={FRESHA_URL} target="_blank" rel="noopener noreferrer">{f.link_fresha}</a>
      </div>

      <!-- Hours -->
      <div class="links">
        <h4>{f.col_hours}</h4>
        <a>{f.hours_salon}</a>
        <a>{f.hours_spa}</a>
        <a>{f.hours_daily}</a>
      </div>

    </div>

    <div class="footer-bottom">
      <span>{f.copyright}</span>
      <a
        href="https://maps.app.goo.gl/pMESauvQZ3H1NGZX6"
        target="_blank"
        rel="noopener noreferrer"
        class="footer-location-link"
      >{f.location} ↗</a>
    </div>
  </div>
</footer>
