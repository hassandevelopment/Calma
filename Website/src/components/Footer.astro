---
const FRESHA_URL  = 'https://www.fresha.com/a/calma-massage-spa-seef-road-3627-nyt1nacu';
const WA_URL      = 'https://wa.me/97366677745';
const INSTAGRAM   = 'https://instagram.com/calma_bh';

interface Props {
  t: Record<string, any>;
  lang: 'en' | 'ar';
}

const { t, lang } = Astro.props;
const f = t.footer;
const homeHref = lang === 'ar' ? '/ar' : '/';
---

<footer class="bg-calma-deep text-text-inverse">
  <div class="content-wrap section-wrap">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-8">

      <!-- Col 1: Brand -->
      <div class="flex flex-col gap-4">
        <a href={homeHref} aria-label={t.aria.logo}>
          <img src="/calma-logo.svg" alt="Calma" width="48" height="48" class="w-12 h-12 rounded-full opacity-90" />
        </a>
        <p class="font-display text-lg text-text-inverse/70 italic">{f.tagline}</p>
      </div>

      <!-- Col 2: Quick links -->
      <div>
        <h3 class="font-body font-semibold text-small uppercase tracking-eyebrow text-text-inverse/50 mb-5">
          {f.links_title}
        </h3>
        <ul class="flex flex-col gap-3">
          {[
            { label: t.nav.experience, href: '#experience' },
            { label: t.nav.services,   href: '#services' },
            { label: t.nav.team,       href: '#team' },
            { label: t.nav.visit,      href: '#visit' },
            { label: f.privacy,        href: lang === 'ar' ? '/ar/privacy' : '/privacy' },
          ].map(({ label, href }) => (
            <li>
              <a href={href} class="text-small text-text-inverse/70 hover:text-text-inverse transition-colors duration-200">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Connect -->
      <div>
        <h3 class="font-body font-semibold text-small uppercase tracking-eyebrow text-text-inverse/50 mb-5">
          {f.connect_title}
        </h3>
        <ul class="flex flex-col gap-3">
          <li>
            <a
              href={INSTAGRAM}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-small text-text-inverse/70 hover:text-text-inverse transition-colors duration-200"
            >
              <!-- Instagram icon -->
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
              </svg>
              {f.instagram}
            </a>
          </li>
          <li>
            <a
              href={WA_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-small text-text-inverse/70 hover:text-text-inverse transition-colors duration-200"
            >
              <!-- WhatsApp icon -->
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
              </svg>
              {f.whatsapp}
            </a>
          </li>
          <li>
            <a
              href={FRESHA_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-small text-text-inverse/70 hover:text-text-inverse transition-colors duration-200"
            >
              <!-- Calendar icon -->
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/>
                <line x1="8" y1="2" x2="8" y2="6"/>
                <line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
              {f.fresha}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-6 border-t border-text-inverse/10 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-small text-text-inverse/40 max-w-none">{f.copyright}</p>
      <a
        href={lang === 'ar' ? '/ar/privacy' : '/privacy'}
        class="text-small text-text-inverse/40 hover:text-text-inverse/70 transition-colors duration-200"
      >
        {f.privacy}
      </a>
    </div>
  </div>
</footer>
