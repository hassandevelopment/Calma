---
import team from '../data/team.json';

interface Props {
  t: Record<string, any>;
  lang: 'en' | 'ar';
}

const { t, lang } = Astro.props;
const tm = t.team_section;
const FRESHA_URL = "https://www.fresha.com/a/calma-massage-spa-seef-road-3627-nyt1nacu";
---

<section class="section team-section" style="background: var(--warm-cream)">
  <div class="container">

    <div class="section-head reveal">
      <h2 class="h2">
        {tm.head_line1} <span class="italic">{tm.head_italic}</span>
      </h2>
      <div class="meta">
        <span class="eyebrow">{tm.eyebrow}</span>
        <p class="lead">{tm.lead}</p>
      </div>
    </div>

    <div class="team-grid">
      {team.map((member: any) => (
        <div class="team-card reveal">
          <div class="team-photo">
            <div class="placeholder" aria-hidden="true">{member.name[0]}</div>
          </div>
          <p class="name">{member.name}</p>
          <span class="role">
            {lang === 'ar' ? member.role_ar ?? member.role : member.role}
            {' · '}<span class="rating">★ {member.rating}</span>
          </span>
        </div>
      ))}
    </div>

    <div style="margin-top: 40px">
      <a class="btn-ghost" href={FRESHA_URL} target="_blank" rel="noopener noreferrer">
        {tm.fresha_cta} <span class="arrow">→</span>
      </a>
    </div>

  </div>
</section>
