---
import team from '../data/team.json';

interface Props {
  t: Record<string, any>;
  lang: 'en' | 'ar';
}

const { t, lang } = Astro.props;
const tm = t.team_section;
const FRESHA_URL = "https://www.fresha.com/a/calma-massage-spa-seef-road-3627-nyt1nacu";
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="section" style="background: var(--warm-cream)">
  <div class="container">

    <div class="section-head reveal">
      <h2 class="h2">
        {tm.head_line1} <span class="italic">{tm.head_italic}</span>
      </h2>
      <div class="meta">
        <span class="eyebrow">{tm.eyebrow}</span>
        <p class="lead">{tm.lead}</p>
      </div>
    </div>

    <div class="team-grid">
      {team.map((member: any, i: number) => (
        <a
          class="team-card reveal"
          href={FRESHA_URL}
          target="_blank"
          rel="noopener noreferrer"
          style={`transition-delay: ${i * 50}ms`}
        >
          <div class="team-photo">
            <img
              src={`${base}/images/${member.photo}`}
              alt={member.name}
              loading="lazy"
              decoding="async"
            />
          </div>
          <p class="name">{member.name}</p>
          <span class="role">
            {lang === 'ar' ? member.role_ar ?? member.role : member.role}
            {' · '}<span class="rating">★ {member.rating}</span>
          </span>
        </a>
      ))}
    </div>

    <div style="margin-top: 40px">
      <a class="btn-ghost" href={FRESHA_URL} target="_blank" rel="noopener noreferrer">
        {tm.fresha_cta} <span class="arrow">→</span>
      </a>
    </div>

  </div>
</section>
