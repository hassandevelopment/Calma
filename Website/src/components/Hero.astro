---
interface Props {
  t: Record<string, any>;
}

const { t } = Astro.props;
const h = t.hero;
const FRESHA_URL = "https://www.fresha.com/a/calma-massage-spa-seef-road-3627-nyt1nacu";
const WHATSAPP_URL = "https://wa.me/97366677745";
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section id="top" class="hero">
  <div class="hero-grid">

    <!-- Copy column -->
    <div class="hero-copy">
      <span class="eyebrow reveal">{h.eyebrow}</span>
      <h1 class="hero-h1 reveal">
        <span class="ar" aria-hidden="true">{h.ar_headline}</span>
        {h.headline_line1} <span class="italic">{h.headline_italic}</span><br/>{h.headline_line2}
      </h1>
      <p class="hero-sub reveal">{h.sub}</p>
      <div class="hero-ctas reveal">
        <a class="btn btn-filled" href={FRESHA_URL} target="_blank" rel="noopener noreferrer">{h.book_cta}</a>
        <a class="btn btn-outline" href={WHATSAPP_URL} target="_blank" rel="noopener noreferrer">{h.whatsapp_cta}</a>
      </div>
      <div class="hero-trust reveal">
        <span class="pill"><span class="star">★</span> {h.trust_rating}</span>
        <span class="sep" aria-hidden="true"></span>
        <span>{h.trust_hours}</span>
      </div>
    </div>

    <!-- Image column -->
    <div class="hero-image">
      <img
        src={`${base}/images/hero-treatment-room.jpg`}
        alt={h.image_alt}
        fetchpriority="high"
        decoding="async"
      />
      <span class="credit">01 · Treatment Room №3</span>

      <!-- Arrival card (visible at 1100px+) -->
      <aside class="arrival-card" aria-label={h.arrival_label}>
        <div class="arrival-eyebrow">{h.arrival_eyebrow}</div>
        <div class="arrival-row">
          <span class="k">{h.arrival_salon_label}</span>
          <span class="v">{h.arrival_salon_hours}</span>
        </div>
        <div class="arrival-row">
          <span class="k">{h.arrival_spa_label}</span>
          <span class="v">{h.arrival_spa_hours}</span>
        </div>
        <div class="arrival-row">
          <span class="k">{h.arrival_walkin_label}</span>
          <span class="v">{h.arrival_walkin_value}</span>
        </div>
      </aside>
    </div>

  </div>
</section>
